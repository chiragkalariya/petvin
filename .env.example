# --- Database (Neon Postgres connection string) ---
# Use the "pooled" connection string from Neon for DATABASE_URL,
# and the "direct" connection string for DIRECT_URL (used by Prisma migrations).
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.neon.tech/shreeji?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.neon.tech/shreeji?sslmode=require"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- Vercel Blob (file uploads) ---
# Get this from Vercel Dashboard -> Storage -> Blob -> .env.local tab
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxx"

# --- Seed script: initial admin account ---
SEED_ADMIN_EMAIL="admin@shreejienterprise.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Admin"
